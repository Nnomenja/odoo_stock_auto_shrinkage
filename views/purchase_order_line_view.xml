<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_final_qty" model="ir.ui.view">
        <field name="name">purchase.order.form.final.qty</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_id']" position="before">
                <field name="final_qty"  column_invisible="parent.state != 'draft'"/>
            </xpath>

        </field>
    </record>
</odoo>