<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_picking_form_inherit_final_qty" model="ir.ui.view">
        <field name="name">stock.picking.form.final.qty</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='move_ids']/list/field[@name='quantity']" position="after">
                <field name="final_qty" optional="show"/>
            </xpath>

        </field>
    </record>

</odoo>